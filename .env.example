# myStockMarket — environment inventory (placement authority: DEVELOPMENT-PLAN.md Appendix D)
# This file documents EVERY secret/config the system uses. Copy relevant lines to the real
# stores; never commit real values. Placement key: [L]=local .env, [V]=Vercel env, [G]=GitHub secrets.

# --- Database (Supabase) ---
DATABASE_URL=            # [L][V][G] transaction pooler — Prisma app reads/writes; pipeline publish
DIRECT_URL=              # [L][V]    direct connection — prisma migrate dev (local only)
SESSION_POOLER_URL=      # [G]       Supavisor session pooler (IPv4) — CI pg_dump + migrate.yml

# --- App auth (plan §4.4) ---
AUTH_USER=               # [L][V] login username (user-chosen at Session-0)
AUTH_PASS_HASH=          # [L][V] bcrypt hash — generated by app/scripts/hash-password.mjs; plaintext discarded
AUTH_COOKIE_SECRET=      # [L][V] generate: openssl rand -hex 32

# --- Pipeline → app handshake ---
CRON_SECRET=             # [L][V][G] bearer for /api/revalidate — generate: openssl rand -hex 32
APP_BASE_URL=            # [L][V][G] deployed app origin — job_b revalidate call

# --- Data providers (standard US signup; smoke-tested by pipeline/scripts/probe_providers.py) ---
ALPACA_KEY_ID=           # [G] EOD bars + universe + corporate actions
ALPACA_SECRET=           # [G]
FINNHUB_KEY=             # [G] metrics + company news (never candles — premium-only)
FMP_KEY=                 # [G] US earnings calendar (bmo/amc)
MARKETAUX_KEY=           # [G] market-wide tagged news snippets
FRED_KEY=                # [G] macro series + release calendar (attribution notice required in UI)
EDGAR_USER_AGENT=        # [G] "Name email@example.com" — SEC requires a real contact; no key needed

# --- LLM briefing (plan Appendix G) ---
ANTHROPIC_API_KEY=       # [G] set a ~$15/mo spend cap in the console at Session-0
MODEL_EXTRACT=claude-haiku-4-5   # [G] stage A per-article extraction (Batch API)
MODEL_SYNTH=claude-sonnet-5      # [G] stage B single synchronous synthesis call

# --- History store (Cloudflare R2) ---
R2_ACCOUNT_ID=           # [G]
R2_ACCESS_KEY_ID=        # [G]
R2_SECRET=               # [G]
R2_BUCKET=msm-history    # [G]

# --- Monitoring (healthchecks.io — check on cron 25 0 * * 2-6, ~45 min grace) ---
HEALTHCHECKS_PING_URL=   # [G] nightly-b /start + success pings (Job B owns the dead-man check)
HEALTHCHECKS_API_KEY=    # [L][G] READ-ONLY key — autonomous alert verification (plan §1.4)
