// Prisma schema — the serving and user-state database (plan Appendix B).
//
// Schema v1 (plan P1 step 1): the data spine. Beyond the pipeline_run heartbeat from v0, this
// adds the tables the nightly pipeline fills and the Desk reads — instruments, price bars, scan
// results, the insert-only signal log — plus the user's watchlist. The remaining tables
// (base rates, setup cards, vol bands, briefings, paper trades, ...) arrive in later phases.
//
// Two connection URLs, and the split matters (Supabase + Prisma, plan Appendix D):
//   url       — the transaction pooler (port 6543). The app's runtime queries go here. It
//               carries ?pgbouncer=true so Prisma disables prepared statements, which the
//               pooler's transaction mode cannot keep across pooled connections.
//   directUrl — a per-session connection (port 5432). Prisma Migrate uses this, never the
//               pooler. On this network it points at Supabase's session pooler rather than the
//               true direct host, because the free-tier direct host is IPv6-only (see .env and
//               DECISIONS.md 2026-07-10).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// One row per pipeline run — the heartbeat of the nightly cloud jobs (Appendix B).
///
/// Keyed by the trading day it processed, so a run is idempotent by date: re-running a night
/// updates that day's row rather than inserting a duplicate. `stageStatus` and `sourceStatus`
/// are JSON maps that will carry per-stage and per-provider health as the pipeline grows; at
/// P0 the hello-run writes them as small placeholder objects.
model PipelineRun {
  /// The US trading day this run processed (its primary key). Stored as a bare date.
  runDate      DateTime  @id @map("run_date") @db.Date
  startedAt    DateTime  @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  /// Per-stage status, e.g. {"ingest": "ok", "compute": "ok"}. JSON so stages can be added
  /// without a migration.
  stageStatus  Json      @map("stage_status")
  /// Per-provider status, e.g. {"alpaca": "ok", "finnhub": "degraded"}.
  sourceStatus Json      @map("source_status")
  /// The Anthropic Batch API id, set once the extraction batch is submitted (null until P3).
  batchId      String?   @map("batch_id")

  @@map("pipeline_run")
}

/// The master list of tradable symbols — the universe (Appendix B).
///
/// Delisted names are RETAINED (never deleted): survivorship-filtered history flatters every
/// backtest, and keeping delisted rows is how the app avoids that trap (Research Report §6.5).
/// `isActive` and `delistedAt` record a symbol's status without dropping its history.
///
/// `exchange` is the venue's raw code as the data provider reports it — NYSE, NASDAQ, AMEX, and
/// also ARCA and BATS, because ETFs list there and the universe is "common stocks + ETFs"
/// (Appendix F). It is a plain string, not an enum: the plan's Appendix F named only
/// NYSE/Nasdaq/AMEX, but the real listing venues for ETFs are more, and a string avoids a schema
/// migration each time a new code appears. The one hard universe rule — "no OTC" — is enforced at
/// ingest (OTC symbols are never inserted), not by the column type. Structural correction logged
/// 2026-07-11.
model Instrument {
  symbol     String    @id
  name       String
  exchange   String
  sector     String?
  industry   String?
  /// SEC Central Index Key, for EDGAR filings (null until matched). Set in P2.
  cik        String?
  isActive   Boolean   @default(true) @map("is_active")
  delistedAt DateTime? @map("delisted_at") @db.Date

  watchlistItems WatchlistItem[]

  @@map("instrument")
}

/// Daily OHLCV for the symbols the app serves — the watchlist plus the indices and sector ETFs,
/// roughly five years each (Appendix B). The full ~5-6k-symbol history lives as Parquet on R2 and
/// is never loaded into Postgres; this table is only what the Desk needs to render.
///
/// Keyed by (symbol, date) so a re-pull of a trading day updates in place rather than duplicating.
model PriceBar {
  symbol String   @map("symbol")
  date   DateTime @db.Date
  open   Float
  high   Float
  low    Float
  close  Float
  /// Split- and dividend-adjusted close, used for indicator math and forward returns.
  adjC   Float    @map("adj_close")
  /// Daily share volume. BigInt because a heavily-traded penny stock can exceed the 2.1B Int32
  /// ceiling on a spike day; the app serialises it down to a JS number for display.
  vol    BigInt

  @@id([symbol, date])
  @@map("price_bar")
}

/// The user's watchlist — the only table in this file the APP writes (via server actions).
///
/// The focus cap (max 3 focus names) is enforced in the UI, not the schema, so the rule can carry
/// its own explanatory copy rather than surfacing as a raw database error (plan Appendix B).
model WatchlistItem {
  id         String     @id @default(cuid())
  symbol     String
  instrument Instrument @relation(fields: [symbol], references: [symbol])
  /// A written reason is required per name — the app makes the user articulate why they are
  /// watching it (Research Report §9.2, the focus-watchlist discipline).
  reason     String
  isFocus    Boolean    @default(false) @map("is_focus")
  addedAt    DateTime   @default(now()) @map("added_at")

  @@index([symbol])
  @@map("watchlist_item")
}

/// One row per symbol that matched a scan preset on a given run (Appendix B). Written nightly by
/// the pipeline. `metrics` is JSON so each preset can carry its own fields (RVOL, gap %, the
/// lottery-risk flag, ...) without a migration per preset.
model ScanResult {
  id        String   @id @default(cuid())
  runDate   DateTime @map("run_date") @db.Date
  /// Which preset matched, e.g. "unusual-volume" (Appendix F keys). A string, not an enum, so a
  /// new preset can ship without a schema migration.
  presetKey String   @map("preset_key")
  symbol    String
  rank      Int
  metrics   Json

  @@index([runDate])
  @@map("scan_result")
}

/// The public track record's foundation: every setup the app flags is logged here, INSERT-ONLY,
/// from P1 (Appendix B, plan §1.5 rule 7). The database GRANT is revoked for UPDATE/DELETE in a
/// migration so the log can never be edited — misses stay visible forever.
///
/// Rate fields (statedWinRate, statedN) are null until P4, when base rates exist; at P1 the
/// signal log records only that a pattern fired and when it resolves.
model SignalLog {
  id            String            @id @default(cuid())
  firedDate     DateTime          @map("fired_date") @db.Date
  symbol        String
  patternKey    String            @map("pattern_key")
  horizonDays   Int               @map("horizon_days")
  statedWinRate Float?            @map("stated_win_rate")
  statedN       Int?              @map("stated_n")
  resolvesOn    DateTime          @map("resolves_on") @db.Date
  resolution    SignalResolution?

  /// One log row per (day, pattern, symbol, horizon) — a rerun of a night inserts nothing new
  /// (the publish uses ON CONFLICT DO NOTHING). This is what makes the nightly job idempotent.
  @@unique([firedDate, patternKey, symbol, horizonDays])
  @@map("signal_log")
}

/// Per-run macro context for the Desk's Macro Pulse module — the VIX, the 10-year yield, and the
/// day's breadth of the ingested universe (plan §9.2 macro strip). Appendix B's schema had no home
/// for these (indices live in price_bar as instruments, but VIX/10-yr are FRED series and breadth
/// is computed across the universe), so this table is added at P1. Structural, logged 2026-07-11.
model MarketContext {
  runDate       DateTime @id @map("run_date") @db.Date
  /// The VIX (FRED VIXCLS) and the 10-year Treasury yield (FRED DGS10), null if FRED was down.
  vix           Float?
  tenYear       Float?   @map("ten_year")

  /// The true index LEVELS from FRED (SP500, NASDAQCOM, DJIA), each with the level before it.
  ///
  /// These exist because an ETF is not its index: SPY traded near 755 while the S&P 500 was near
  /// 6,800, and the Desk used to print the former under the latter's name. The prior level is
  /// stored alongside each level because the app computes the one-day change by subtracting them —
  /// it never sees the pipeline's observations, so a prior it does not have is a change it must
  /// render as "—" rather than invent. Every column is nullable: each FRED series fails alone, and
  /// a null level sends that slot to its ETF proxy, labelled as a proxy on-surface.
  /// (UI-REDESIGN-PLAN §6.1. Russell 2000 has no free FRED series, so IWM stays an honest proxy.)
  sp500                  Float?
  sp500Prior             Float?  @map("sp500_prior")
  nasdaqComposite        Float?  @map("nasdaq_composite")
  nasdaqCompositePrior   Float?  @map("nasdaq_composite_prior")
  djia                   Float?
  djiaPrior              Float?  @map("djia_prior")

  /// Breadth of the ingested universe on the run date.
  advancers     Int
  decliners     Int
  pctAbove50dma Float    @map("pct_above_50dma")

  @@map("market_context")
}

/// Company and market news that explains why names moved (plan Appendix B, P2). Written by the
/// nightly catalyst ingest from Finnhub (per-ticker), Marketaux (market-wide, tagged), and EDGAR
/// (filings). One row per article, deduplicated by (provider, url) so a rerun adds nothing new.
///
/// `tickers` is a Postgres text array — an article can name several symbols. `eventType` is the
/// catalyst-type classification (earnings, guidance, analyst, filing, ...) the matcher assigns, null
/// until classified. `extract` is reserved for the P3 LLM structured extract.
model NewsItem {
  id          String   @id @default(cuid())
  publishedAt DateTime @map("published_at")
  provider    String
  url         String
  headline    String
  snippet     String
  /// The symbols this article was tagged with (a news item can mention several).
  tickers     String[]
  eventType   String?  @map("event_type")
  sentiment   Float?
  extract     Json?

  @@unique([provider, url])
  @@index([publishedAt])
  @@map("news_item")
}

/// The forward event calendar — earnings, macro releases, Fed days, dividends (plan Appendix B, P2).
/// Written nightly from FMP (earnings + consensus) and FRED (economic releases). The nightly refresh
/// replaces the forward window each run, so the calendar always reflects the latest schedule.
///
/// `kind` is a plain string (earnings|macro|fed|div|other), not an enum, so a new event type ships
/// without a migration. `symbol` is null for market-wide events (a Fed day, a CPI print). `timing`
/// (bmo|amc|time) is nullable — FMP's /stable/ endpoint does not carry the time of day (logged).
model CalendarEvent {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  kind       String
  symbol     String?
  timing     String?
  title      String
  /// Consensus and prior figures for a data release or earnings report, when known.
  consensus  Float?
  prior      Float?
  /// A coarse importance marker ("high" | "medium"), null on rows written before the allowlist.
  importance String?
  /// The chip the Desk renders: CPI, JOBS, PPI, GDP, PCE, RETAIL, FOMC, EARNINGS. One vocabulary,
  /// set by the pipeline's release allowlist (UI-REDESIGN-PLAN §6.2, Appendix C) — never derived
  /// from the raw provider name, so the calendar cannot start speaking in FRED's dialect again.
  code       String?

  @@index([date])
  @@map("calendar_event")
}

/// The evening (and optional pre-open) briefing — the editorial heart (plan Appendix B, P3).
///
/// Keyed by the trading day it covers, so a rerun of a night updates that day's briefing rather
/// than inserting a duplicate. `amJson` and `pmJson` hold the two editions in the Appendix G shape
/// (the AM pre-open glance and the PM after-close read); `pmJson` is null until the PM edition is
/// written. `verificationJson` records every decision the deterministic gate made — which entities
/// were checked, which were flagged, and why a held night was held — so a published or withheld
/// briefing is fully auditable. `modelMeta` carries the models and token/cost metadata of the run.
///
/// `status` is a plain string: "published" (the gate passed) or "held" (a flagged number in the
/// Today's-focus block, or more than two flags — the app then shows "briefing unavailable" over the
/// verified scans rather than a fabricated sentence). A string, not an enum, so a new status ships
/// without a migration.
model Briefing {
  runDate          DateTime @id @map("run_date") @db.Date
  amJson           Json     @map("am_json")
  pmJson           Json?    @map("pm_json")
  verificationJson Json     @map("verification_json")
  modelMeta        Json     @map("model_meta")
  status           String

  @@map("briefing")
}

/// The user's PM journal — one reflection per evening, and the accountability record behind the
/// scorecard (plan Appendix B, P3/P4). App-writable (✎). `prompt` is the question that was posed;
/// `body` is what the user wrote. The forecast fields are optional and fill in over later phases:
/// `forecast` is the free-text call, `probability` its stated confidence (0..1), `resolvesOn` the
/// date it can be graded, `outcome` how it resolved, and `brier` the computed Brier score. Kept
/// nullable so an entry can be a plain reflection with no forecast attached.
model JournalEntry {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  prompt      String
  body        String
  forecast    String?
  probability Float?
  resolvesOn  DateTime? @map("resolves_on") @db.Date
  outcome     String?
  brier       Float?

  @@index([date])
  @@map("journal_entry")
}

/// Base-rate statistics per pattern × universe bucket × horizon × regime (plan Appendix B, P4).
///
/// One row is the honest answer to "the last N times this pattern appeared in this bucket and
/// regime, how often was price higher H days later" — with the Wilson interval (ciLow/ciHigh), the
/// forward-return percentiles, and the always-up baseline for the same bucket+horizon so a rate can
/// never pose as an edge it does not have. Provenance rides along: the key paper's year, the RR
/// Part 4 evidence grade, and the decay note. Recomputed nightly; keyed so a recompute replaces in
/// place. `n < 30` is suppressed at display (the N-gate), not here — the raw counts are always kept.
model BaseRateStat {
  id              String   @id @default(cuid())
  patternKey      String   @map("pattern_key")
  universe        String
  horizonDays     Int      @map("horizon_days")
  regime          String
  n               Int
  wins            Int
  winRate         Float    @map("win_rate")
  ciLow           Float    @map("ci_low")
  ciHigh          Float    @map("ci_high")
  fwdP10          Float?   @map("fwd_p10")
  fwdMedian       Float?   @map("fwd_median")
  fwdP90          Float?   @map("fwd_p90")
  baselineUpRate  Float?   @map("baseline_up_rate")
  publicationYear Int?     @map("publication_year")
  evidenceGrade   String   @map("evidence_grade")
  decayNote       String?  @map("decay_note")
  computedAt      DateTime @default(now()) @map("computed_at")

  setupCards SetupCard[]

  @@unique([patternKey, universe, horizonDays, regime])
  @@map("base_rate_stat")
}

/// A setup card — a pattern that fired on a served symbol, shown on the Desk with its base rate and
/// weakeners (plan Appendix B, P4, §3.6). `tier` is the tendency tier (strong/moderate/weak) from
/// the Appendix F bands, capped to weak when the CI spans the baseline. `state` is the rendered
/// card view-model; `weakeners` is the per-pattern checkbox state, which the app writes (✎). The
/// card links to the base_rate_stat it was scored against, so the exact N and interval shown are
/// auditable. Replaced per run date.
model SetupCard {
  id         String        @id @default(cuid())
  runDate    DateTime      @map("run_date") @db.Date
  symbol     String
  patternKey String        @map("pattern_key")
  tier       String
  state      Json
  weakeners  Json
  baseRateId String?       @map("base_rate_id")
  baseRate   BaseRateStat? @relation(fields: [baseRateId], references: [id])

  @@index([runDate])
  @@map("setup_card")
}

/// Empirical volatility bands per watchlist symbol (plan Appendix B, P4, Appendix F). The one
/// forward-looking number the app allows — a range with a frequency label, ALWAYS rendered with the
/// regime-break caveat (§1.5 rule 1). `lo`/`hi` are return fractions; the chart projects them from
/// the current close. `horizonDays` is 5, 10, or 20 — nothing beyond 20 by schema. `coverage` is
/// 0.5 (p25–p75) or 0.8 (p10–p90). Replaced per run date.
model VolBand {
  id          String   @id @default(cuid())
  symbol      String
  runDate     DateTime @map("run_date") @db.Date
  horizonDays Int      @map("horizon_days")
  lo          Float
  hi          Float
  coverage    Float
  label       String

  @@index([runDate])
  @@map("vol_band")
}

/// The resolved outcome of a fired signal (plan Appendix B, P4). INSERT-ONLY, like the signal log
/// it resolves: a permanent record that a pattern's horizon passed and how it turned out, so the
/// track record can show the app's own misses. One resolution per signal (unique), outcome is
/// hit / miss / na (na = the horizon could not be resolved, e.g. a delisting). The insert-only
/// guarantee is enforced by a trigger in the migration, not by a grant (a table owner bypasses
/// grants — see the signal_log lesson).
model SignalResolution {
  id         String    @id @default(cuid())
  signalId   String    @unique @map("signal_id")
  signal     SignalLog @relation(fields: [signalId], references: [id])
  outcome    String
  resolvedAt DateTime  @default(now()) @map("resolved_at")

  @@map("signal_resolution")
}

/// The Academy review queue's Leitner state, one row per glossary concept the user has actually
/// encountered (plan §7 P5 step 5). A concept enters when its glossary popover is first opened on the
/// Desk — a genuine encounter, not merely a render — starting in box 1. A correct review promotes it
/// to a higher box scheduled further out; a wrong review resets it to box 1. `dueOn` drives the
/// daily queue (capped at five in lib/review.ts). The scheduling math lives in lib/review.ts and is
/// unit-tested there; this table only persists the result. Keyed by the concept slug so an exposure
/// is idempotent — re-encountering a known concept does not restart its schedule.
model ConceptState {
  /// The glossary key, e.g. "rvol" (its primary key — one row per concept).
  concept        String    @id
  /// The Leitner box, 1–5. Higher boxes come due further out.
  box            Int       @default(1)
  /// The next review date (a bare calendar day).
  dueOn          DateTime  @map("due_on") @db.Date
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  timesSeen      Int       @default(0) @map("times_seen")
  timesCorrect   Int       @default(0) @map("times_correct")

  @@index([dueOn])
  @@map("concept_state")
}

/// One row per Academy lesson the user has read (plan §7 P5 step 6). Completion is the signal behind
/// the M3 soft gate: once all four M3 lessons are here, the pattern modules (M4/M5) stop showing their
/// "do risk first" notice. Written when a lesson page is viewed (a read beacon). Keyed by slug so a
/// re-read is idempotent.
model LessonProgress {
  slug        String   @id
  completedAt DateTime @default(now()) @map("completed_at")

  @@map("lesson_progress")
}

/// The paper-trading ledger (plan §7 P6 step 1, Appendix B). Paper trades are the ONLY orders the app
/// places — no brokerage integration in v1 (§8.1, paper-first). A trade fills at the next-session open
/// moved against the trader by half the bucket's at-open spread plus slippage (lib/paper.ts), so the
/// certain cost is recorded, never a mid-price fantasy. `signalViewedAt` (when set) is the moment the
/// user saw the fired signal that prompted the order — the cooling-off interstitial reads it. A trade
/// opens `open` and becomes `closed` on exit, when realized P&L is stored. All prices are simulated;
/// the honesty rules forbid seeding this table on production (dev/test only).
model PaperTrade {
  id             String    @id @default(cuid())
  symbol         String
  /// "buy" or "sell" (the opening side).
  side           String
  /// The reference-class bucket ("large-mid" or "small") — sets the at-open spread used for the fill.
  bucket         String
  quantity       Int
  /// The next-session open the fill was priced from, and the simulated fill after costs.
  referenceOpen  Float     @map("reference_open")
  fillPrice      Float     @map("fill_price")
  /// How far the fill moved against the trader, in basis points (half-spread + slippage).
  costBps        Float     @map("cost_bps")
  /// When the user viewed the fired signal that prompted this order (drives cooling-off), if any.
  signalViewedAt DateTime? @map("signal_viewed_at")
  openedAt       DateTime  @default(now()) @map("opened_at")
  /// "open" or "closed".
  status         String    @default("open")
  exitFillPrice  Float?    @map("exit_fill_price")
  closedAt       DateTime? @map("closed_at")
  realizedPnl    Float?    @map("realized_pnl")
  note           String?

  @@index([status])
  @@index([openedAt])
  @@map("paper_trade")
}
