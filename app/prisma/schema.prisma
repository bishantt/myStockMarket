// Prisma schema — the serving and user-state database (plan Appendix B).
//
// Two connection URLs, and the split matters (Supabase + Prisma, Appendix D):
//   url       — the transaction pooler (port 6543), for the app's runtime queries. It carries
//               ?pgbouncer=true so Prisma disables prepared statements, which the pooler's
//               transaction mode cannot keep across pooled connections.
//   directUrl — a per-session connection (port 5432), for Prisma Migrate. On this network it points
//               at Supabase's session pooler, because the free-tier direct host is IPv6-only
//               (see .env and DECISIONS.md 2026-07-10).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// One row per pipeline run — the heartbeat of the nightly cloud jobs (Appendix B). Keyed by the
/// trading day it processed, so a run is idempotent by date: re-running a night updates that day's row.
/// `stageStatus`/`sourceStatus` are JSON maps of per-stage and per-provider health.
model PipelineRun {
  /// The US trading day this run processed (its primary key). Stored as a bare date.
  runDate      DateTime  @id @map("run_date") @db.Date
  startedAt    DateTime  @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  /// Per-stage status, e.g. {"ingest": "ok", "compute": "ok"}. JSON so stages can be added
  /// without a migration.
  stageStatus  Json      @map("stage_status")
  /// Per-provider status, e.g. {"alpaca": "ok", "finnhub": "degraded"}.
  sourceStatus Json      @map("source_status")
  /// The Anthropic Batch API id, set once the extraction batch is submitted (null until P3).
  batchId      String?   @map("batch_id")

  @@map("pipeline_run")
}

/// The master list of tradable symbols — the universe (Appendix B). Delisted names are RETAINED, never
/// deleted: survivorship-filtered history flatters every backtest (RR §6.5), so `isActive`/`delistedAt`
/// record status without dropping history. `exchange` is the provider's raw venue code (NYSE, NASDAQ,
/// AMEX, ARCA, BATS — ETFs list there too) as a plain string, not an enum, so a new code needs no
/// migration; the one hard rule ("no OTC") is enforced at ingest, not by the column (logged 2026-07-11).
model Instrument {
  symbol     String    @id
  name       String
  exchange   String
  sector     String?
  industry   String?
  /// SEC Central Index Key, for EDGAR filings (null until matched). Set in P2.
  cik        String?
  isActive   Boolean   @default(true) @map("is_active")
  delistedAt DateTime? @map("delisted_at") @db.Date

  watchlistItems WatchlistItem[]

  @@map("instrument")
}

/// Daily OHLCV for the symbols the app serves — the watchlist plus indices and sector ETFs, ~5 years each
/// (Appendix B). The full ~5-6k-symbol history lives as Parquet on R2, never loaded into Postgres; this is
/// only what the Desk needs. Keyed by (symbol, date) so a re-pull updates in place.
model PriceBar {
  symbol String   @map("symbol")
  date   DateTime @db.Date
  open   Float
  high   Float
  low    Float
  close  Float
  /// Split- and dividend-adjusted close, used for indicator math and forward returns.
  adjC   Float    @map("adj_close")
  /// Daily share volume. BigInt because a heavily-traded penny stock can exceed the 2.1B Int32
  /// ceiling on a spike day; the app serialises it down to a JS number for display.
  vol    BigInt

  @@id([symbol, date])
  @@map("price_bar")
}

/// The user's watchlist — the only table in this file the APP writes (via server actions). The focus cap
/// (max 3 focus names) is enforced in the UI, not the schema, so the rule carries its own copy rather than
/// a raw database error (Appendix B).
model WatchlistItem {
  id         String     @id @default(cuid())
  symbol     String
  instrument Instrument @relation(fields: [symbol], references: [symbol])
  /// A written reason is required per name — the app makes the user articulate why they are
  /// watching it (Research Report §9.2, the focus-watchlist discipline).
  reason     String
  isFocus    Boolean    @default(false) @map("is_focus")
  addedAt    DateTime   @default(now()) @map("added_at")

  @@index([symbol])
  @@map("watchlist_item")
}

/// One row per symbol that matched a scan preset on a run (Appendix B), written nightly. `metrics` is JSON
/// so each preset carries its own fields (RVOL, gap %, the lottery-risk flag) without a migration per preset.
model ScanResult {
  id        String   @id @default(cuid())
  runDate   DateTime @map("run_date") @db.Date
  /// Which preset matched, e.g. "unusual-volume" (Appendix F keys). A string, not an enum, so a
  /// new preset can ship without a schema migration.
  presetKey String   @map("preset_key")
  symbol    String
  rank      Int
  metrics   Json

  @@index([runDate])
  @@map("scan_result")
}

/// The public track record's foundation: every setup the app flags, logged here INSERT-ONLY from P1
/// (Appendix B, §1.5 rule 7). The GRANT for UPDATE/DELETE is revoked in a migration, so the log can never be
/// edited — misses stay visible forever. Rate fields (statedWinRate/statedN) are null until P4.
model SignalLog {
  id            String            @id @default(cuid())
  firedDate     DateTime          @map("fired_date") @db.Date
  symbol        String
  patternKey    String            @map("pattern_key")
  horizonDays   Int               @map("horizon_days")
  statedWinRate Float?            @map("stated_win_rate")
  statedN       Int?              @map("stated_n")
  resolvesOn    DateTime          @map("resolves_on") @db.Date
  resolution    SignalResolution?

  /// One log row per (day, pattern, symbol, horizon) — a rerun of a night inserts nothing new
  /// (the publish uses ON CONFLICT DO NOTHING). This is what makes the nightly job idempotent.
  @@unique([firedDate, patternKey, symbol, horizonDays])
  @@map("signal_log")
}

/// Per-run macro context for the Macro Pulse — VIX, the 10-year yield, and the day's breadth of the
/// ingested universe (§9.2). Appendix B had no home for these (VIX/10-yr are FRED series, breadth is
/// computed), so this table is added at P1 (structural, logged 2026-07-11).
model MarketContext {
  runDate       DateTime @id @map("run_date") @db.Date
  /// The VIX (FRED VIXCLS) and the 10-year Treasury yield (FRED DGS10), null if FRED was down.
  vix           Float?
  tenYear       Float?   @map("ten_year")

  /// The true index LEVELS from FRED (SP500, NASDAQCOM, DJIA), each with the level before it. These exist
  /// because an ETF is not its index (SPY near 755 while the S&P was near 6,800, printed under its name).
  /// The prior is stored beside each level because the app computes the one-day change by subtracting them —
  /// it never sees the pipeline's observations, so a prior it lacks is a change it renders "—", not invents.
  /// Every column is nullable: each FRED series fails alone, and a null sends that slot to its labelled ETF
  /// proxy (UI-REDESIGN §6.1; Russell 2000 has no free FRED series, so IWM stays an honest proxy).
  sp500                  Float?
  sp500Prior             Float?  @map("sp500_prior")
  nasdaqComposite        Float?  @map("nasdaq_composite")
  nasdaqCompositePrior   Float?  @map("nasdaq_composite_prior")
  djia                   Float?
  djiaPrior              Float?  @map("djia_prior")

  /// Breadth of the ingested universe on the run date.
  advancers     Int
  decliners     Int
  pctAbove50dma Float    @map("pct_above_50dma")

  /// The date the index LEVELS above are actually for (News plan, N1). Not always this run's date, and
  /// pretending otherwise is the bug this closes: FRED posts index closes AFTER both jobs run (Nasdaq
  /// ~11:38pm ET vs Job A at 6:37pm), so a level fetched tonight can be last session's — and the upsert used
  /// to overwrite a good level with NULL on a flaky night. Now a failed fetch LEAVES the stored level alone,
  /// and this date lets the Desk say "as of Jul 9" instead of implying it is tonight's (C7).
  indexLevelsAsOf DateTime? @map("index_levels_as_of") @db.Date

  @@map("market_context")
}

/// Company and market news that explains why names moved (Appendix B, P2). Written nightly from Finnhub
/// (per-ticker), Marketaux (market-wide, tagged) and EDGAR (filings); one row per article, deduped by
/// (provider, url). `tickers` is a Postgres text array; `eventType` is the catalyst classification, null
/// until classified; `extract` is reserved for the P3 LLM structured extract.
model NewsItem {
  id          String   @id @default(cuid())
  publishedAt DateTime @map("published_at")
  provider    String
  url         String
  headline    String
  snippet     String
  /// The symbols this article was tagged with (a news item can mention several).
  tickers     String[]
  eventType   String?  @map("event_type")
  sentiment   Float?
  extract     Json?

  /// Added by the News plan (N4). The providers already send all of this and we threw it away; the Front
  /// Page needs it. The outlet's name ("Reuters"), for the corroboration count and each card's byline.
  source      String?
  /// The image URL AS RECEIVED from the provider or the article's og:image — a candidate, not a serving URL:
  /// the copy we render lives in news_image, fetched into our own bucket. We never hotlink at render (0.2.1).
  imageUrl    String?  @map("image_url")
  /// The provider's own category ("general", "merger") — an ingest hint, not our taxonomy.
  category    String?
  /// Marketaux's per-entity industry strings. Feeds the deterministic sector map (Appendix E), the only
  /// thing allowed to assign a sector — the LLM never invents taxonomy (0.2.4).
  industries  String[]
  /// The story this article belongs to, once clustering has run. Null until then, and forever for articles
  /// ingested before the Front Page existed — old rows never join new clusters.
  clusterId   String?  @map("cluster_id")

  @@unique([provider, url])
  @@index([publishedAt])
  @@index([clusterId])
  @@map("news_item")
}

/// The forward event calendar — earnings, macro releases, Fed days, dividends (Appendix B, P2). Written
/// nightly from FMP (earnings + consensus) and FRED; the refresh replaces the forward window each run.
/// `kind` is a plain string, not an enum; `symbol` is null for market-wide events; `timing` (bmo|amc|time)
/// is nullable — FMP's /stable/ endpoint carries no time of day (logged).
model CalendarEvent {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  kind       String
  symbol     String?
  timing     String?
  title      String
  /// Consensus and prior figures for a data release or earnings report, when known.
  consensus  Float?
  prior      Float?
  /// A coarse importance marker ("high" | "medium"), null on rows written before the allowlist.
  importance String?
  /// The chip the Desk renders: CPI, JOBS, PPI, GDP, PCE, RETAIL, FOMC, EARNINGS. One vocabulary set by the
  /// pipeline's release allowlist (UI-REDESIGN §6.2, Appendix C), never the raw provider name — so the
  /// calendar cannot start speaking in FRED's dialect again.
  code       String?

  @@index([date])
  @@map("calendar_event")
}

/// The evening (and optional pre-open) briefing — the editorial heart (Appendix B, P3). Keyed by the day it
/// covers, so a rerun updates rather than duplicates. `amJson`/`pmJson` hold the two editions (Appendix G
/// shape); `pmJson` is null until the PM edition is written. `verificationJson` records every gate decision
/// (which entities checked, which flagged, why a held night was held), so a published or withheld briefing
/// is auditable. `modelMeta` carries the run's model/cost metadata. `status` is a plain string: "published"
/// (gate passed) or "held" (a flagged number in Today's-focus, or >2 flags — the app then shows "briefing
/// unavailable" over the verified scans rather than a fabricated sentence).
model Briefing {
  runDate          DateTime @id @map("run_date") @db.Date
  amJson           Json     @map("am_json")
  pmJson           Json?    @map("pm_json")
  verificationJson Json     @map("verification_json")
  modelMeta        Json     @map("model_meta")
  status           String

  @@map("briefing")
}

/// The user's PM journal — one reflection per evening, the accountability record behind the scorecard
/// (Appendix B, P3/P4). App-writable (✎). `prompt` is the question posed, `body` what the user wrote. The
/// forecast fields fill in over later phases (`forecast` the call, `probability` its confidence 0..1,
/// `resolvesOn` when it can be graded, `outcome` how it resolved, `brier` the score) — nullable, so an entry
/// can be a plain reflection with no forecast.
model JournalEntry {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  prompt      String
  body        String
  forecast    String?
  probability Float?
  resolvesOn  DateTime? @map("resolves_on") @db.Date
  outcome     String?
  brier       Float?

  @@index([date])
  @@map("journal_entry")
}

/// Base-rate statistics per pattern × universe bucket × horizon × regime (Appendix B, P4). One row answers
/// "the last N times this pattern appeared in this bucket and regime, how often was price higher H days
/// later" — with the Wilson interval, forward-return percentiles, and the always-up baseline for the same
/// bucket+horizon so a rate can never pose as an edge it lacks. Provenance rides along (paper year, RR Part 4
/// grade, decay note). Recomputed nightly, keyed so a recompute replaces in place. `n < 30` is suppressed at
/// display (the N-gate), not here — the raw counts are always kept.
model BaseRateStat {
  id              String   @id @default(cuid())
  patternKey      String   @map("pattern_key")
  universe        String
  horizonDays     Int      @map("horizon_days")
  regime          String
  n               Int
  wins            Int
  winRate         Float    @map("win_rate")
  ciLow           Float    @map("ci_low")
  ciHigh          Float    @map("ci_high")
  fwdP10          Float?   @map("fwd_p10")
  fwdMedian       Float?   @map("fwd_median")
  fwdP90          Float?   @map("fwd_p90")
  baselineUpRate  Float?   @map("baseline_up_rate")
  publicationYear Int?     @map("publication_year")
  evidenceGrade   String   @map("evidence_grade")
  decayNote       String?  @map("decay_note")
  computedAt      DateTime @default(now()) @map("computed_at")

  setupCards SetupCard[]

  @@unique([patternKey, universe, horizonDays, regime])
  @@map("base_rate_stat")
}

/// A setup card — a pattern that fired on a served symbol, shown with its base rate and weakeners (Appendix
/// B, P4, §3.6). `tier` is the tendency tier (strong/moderate/weak) from Appendix F, capped to weak when the
/// CI spans the baseline. `state` is the rendered view-model; `weakeners` is the app-written checkbox state.
/// It links to the base_rate_stat it was scored against, so the exact N and interval are auditable. Replaced
/// per run date.
model SetupCard {
  id         String        @id @default(cuid())
  runDate    DateTime      @map("run_date") @db.Date
  symbol     String
  patternKey String        @map("pattern_key")
  tier       String
  state      Json
  weakeners  Json
  baseRateId String?       @map("base_rate_id")
  baseRate   BaseRateStat? @relation(fields: [baseRateId], references: [id])

  @@index([runDate])
  @@map("setup_card")
}

/// Empirical volatility bands per watchlist symbol (Appendix B, P4, Appendix F). The one forward-looking
/// number the app allows — a range with a frequency label, ALWAYS rendered with the regime-break caveat
/// (§1.5 rule 1). `lo`/`hi` are return fractions; `horizonDays` is 5, 10, or 20 (nothing beyond by schema);
/// `coverage` is 0.5 or 0.8. Replaced per run date.
model VolBand {
  id          String   @id @default(cuid())
  symbol      String
  runDate     DateTime @map("run_date") @db.Date
  horizonDays Int      @map("horizon_days")
  lo          Float
  hi          Float
  coverage    Float
  label       String
  /// How many historical paths this band was drawn from, and over what trailing window. The Range Ladder
  /// prints both on every row (UI-REDESIGN §3.8): a range shown without its sample size is an assertion, not
  /// evidence. Nullable only for rows written before this column existed.
  n           Int?
  windowDays  Int?     @map("window_days")

  @@index([runDate])
  @@map("vol_band")
}

/// The resolved outcome of a fired signal (Appendix B, P4). INSERT-ONLY, like the signal log it resolves: a
/// permanent record of how a pattern's horizon turned out, so the track record can show the app's misses.
/// One per signal; outcome is hit/miss/na (na = unresolvable, e.g. a delisting). Insert-only is enforced by
/// a migration trigger, not a grant (a table owner bypasses grants — the signal_log lesson).
model SignalResolution {
  id         String    @id @default(cuid())
  signalId   String    @unique @map("signal_id")
  signal     SignalLog @relation(fields: [signalId], references: [id])
  outcome    String
  resolvedAt DateTime  @default(now()) @map("resolved_at")

  @@map("signal_resolution")
}

/// The Academy review queue's Leitner state, one row per glossary concept the user has actually encountered
/// (§7 P5 step 5). A concept enters when its popover is first opened on the Desk (a genuine encounter, not a
/// render), in box 1; a correct review promotes it further out, a wrong one resets to box 1. `dueOn` drives
/// the daily queue (capped at five in lib/review.ts, where the scheduling math lives and is tested). Keyed by
/// slug, so re-encountering a known concept does not restart its schedule.
model ConceptState {
  /// The glossary key, e.g. "rvol" (its primary key — one row per concept).
  concept        String    @id
  /// The Leitner box, 1–5. Higher boxes come due further out.
  box            Int       @default(1)
  /// The next review date (a bare calendar day).
  dueOn          DateTime  @map("due_on") @db.Date
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  timesSeen      Int       @default(0) @map("times_seen")
  timesCorrect   Int       @default(0) @map("times_correct")

  @@index([dueOn])
  @@map("concept_state")
}

/// One row per Academy lesson the user has read (§7 P5 step 6). Completion is the signal behind the M3 soft
/// gate: once all four M3 lessons are here, the pattern modules (M4/M5) stop showing their "do risk first"
/// notice. Written on view (a read beacon), keyed by slug so a re-read is idempotent.
model LessonProgress {
  slug        String   @id
  completedAt DateTime @default(now()) @map("completed_at")

  @@map("lesson_progress")
}

/// The paper-trading ledger (§7 P6 step 1, Appendix B). Paper trades are the ONLY orders the app places — no
/// brokerage in v1 (§8.1, paper-first). A trade fills at the next-session open moved against the trader by
/// half the bucket's at-open spread plus slippage (lib/paper.ts), so the certain cost is recorded, never a
/// mid-price fantasy. `signalViewedAt` (when set) is when the user saw the fired signal — the cooling-off
/// interstitial reads it. Opens `open`, becomes `closed` on exit with realized P&L. Simulated; never seeded
/// on production.
model PaperTrade {
  id             String    @id @default(cuid())
  symbol         String
  /// "buy" or "sell" (the opening side).
  side           String
  /// The reference-class bucket ("large-mid" or "small") — sets the at-open spread used for the fill.
  bucket         String
  quantity       Int
  /// The next-session open the fill was priced from, and the simulated fill after costs.
  referenceOpen  Float     @map("reference_open")
  fillPrice      Float     @map("fill_price")
  /// How far the fill moved against the trader, in basis points (half-spread + slippage).
  costBps        Float     @map("cost_bps")
  /// When the user viewed the fired signal that prompted this order (drives cooling-off), if any.
  signalViewedAt DateTime? @map("signal_viewed_at")
  openedAt       DateTime  @default(now()) @map("opened_at")
  /// "open" or "closed".
  status         String    @default("open")
  exitFillPrice  Float?    @map("exit_fill_price")
  closedAt       DateTime? @map("closed_at")
  realizedPnl    Float?    @map("realized_pnl")
  note           String?

  @@index([status])
  @@index([openedAt])
  @@map("paper_trade")
}

// ─────────────────────────────────────────────────────────────────────────────────────────────
// The News & Control plan (NEWS-AND-CONTROL-PLAN.md, Appendix C). Landed whole at N0 so the seed
// — which every later phase asserts against — has tables to write into. The CODE that fills these
// arrives with its phase: macro_stat at N3, the news trio at N4, manual_run at N6.
// ─────────────────────────────────────────────────────────────────────────────────────────────

/// One macro observation, keyed by (series, the date the SOURCE says it is for). A separate table from
/// market_context on purpose: that is one row per night, but these stats each publish on their own schedule
/// (mortgage weekly, CPI monthly, gold/FX daily), and storing them as market_context columns would force
/// every one to inherit the run's date — a Thursday mortgage rate stamped "Tuesday" is a lie (C2/C7). So the
/// as-of date is part of the key, and `asOfLabel` carries the human window ("wk of Jul 9", "Jun 2026"). A
/// source that published nothing new writes no row — not staleness, the cadence, and the label says so.
model MacroStat {
  /// "mortgage30us" | "cpi_yoy" | "gold_usd" | "usd_npr" | "mood" — the closed set lives in code.
  seriesKey String   @map("series_key")
  /// The date the SOURCE reports the observation for — never our fetch date.
  asOfDate  DateTime @map("as_of_date") @db.Date
  value     Float
  /// The previous observation, so a period-over-period delta needs no second query.
  prior     Float?
  /// The window as the reader sees it: "wk of Jul 9", "Jun 2026", "Jul 11".
  asOfLabel String   @map("as_of_label")
  /// Which source answered — the label follows this, mechanically (C6). e.g. "fred" | "nrb" | "erapi".
  sourceKey String   @map("source_key")
  fetchedAt DateTime @map("fetched_at")
  /// Per-series extras. The Mood gauge's component breakdown lives here — and because C8 makes the
  /// breakdown a REQUIRED prop, a gauge row without it cannot render at all.
  meta      Json?

  @@id([seriesKey, asOfDate])
  @@index([seriesKey, asOfDate(sort: Desc)])
  @@map("macro_stat")
}

/// One story. Not one article — one STORY. A single catalyst arrives as N articles from N outlets;
/// clustering them (deterministically, in newsdesk/cluster.py — no LLM) turns a feed into a front page: the
/// reader sees the event once, with its corroboration count. `significance` is a fixed formula (Appendix E),
/// never a model and never attention — there is no click, view or popularity column here, and that absence is
/// the deepest guard against this room drifting into a trending feed (ruling C1).
model NewsCluster {
  /// sha1 of the SEED member's canonical url (the earliest article), so the id is stable as later
  /// articles join the cluster over the following evenings.
  id           String   @id
  /// The last night this cluster was updated — stories span evenings and keep accumulating.
  runDate      DateTime @map("run_date") @db.Date
  firstSeen    DateTime @map("first_seen")
  headline     String
  eventType    String   @map("event_type")
  sectors      String[]
  themes       String[]
  tickers      String[]
  significance Float
  /// How many distinct outlets carried it. Corroboration is evidence; volume of coverage is not.
  sources      Int
  /// The one-line "so what". Null when the gate dropped it or the cluster was outside the narrated top-20;
  /// a null prints NOTHING — never a placeholder (P9).
  whyItMatters String?  @map("why_it_matters")
  affectedNote String?  @map("affected_note")
  extract      Json
  /// What the gate checked and what it decided, kept so a dropped line can be explained later.
  verification Json
  /// The articles this story was built from — [{ source, url, headline, published }] — SNAPSHOTTED at
  /// publish. `sources` above is only a COUNT, and a corroboration count the reader cannot check is
  /// unverifiable — this is what the card's outlet line and the source list render from, so "3 sources" can
  /// be opened rather than believed.
  articles     Json     @default("[]")
  /// PD7 (Part 9.3) — the v2 insight's context section: 2–3 mechanical sentences placing tonight's move,
  /// narrated ONLY from cited registry stats. Null when the gate dropped it, the narrator had nothing to add,
  /// or the cluster sat outside the depth budget's top 8 — `verification.sections` records which, per section.
  context      String?
  /// PD7 — the watch section: the already-scheduled calendar facts a reader should know are dated.
  /// SNAPSHOTTED rows [{ stat_id, key, code, title, date, kind }]; the narrator may only SELECT from the
  /// calendar rows it was shown, never author one (E4).
  watch        Json     @default("[]")
  /// PD7 (Part 9.5) — what the models actually cost this story: {model_extract, model_synth, extract_count,
  /// note_version, usage per stage}. Written from the API's OWN usage fields, never estimated. The provenance
  /// footer prints from this instead of hardcoding a model name it cannot know.
  modelMeta    Json?    @map("model_meta")
  imageId      String?  @map("image_id")

  image NewsImage?     @relation(fields: [imageId], references: [id])
  links CatalystLink[]

  @@index([runDate, significance(sort: Desc)])
  @@map("news_cluster")
}

/// A cluster's link to one ticker, with the ticker's numbers SNAPSHOTTED at publish. The snapshot is the
/// point: if the story page recomputed a move from live tables, the feed's number and the card's could drift
/// apart within one night. Freezing them at publish means the front page and the story always agree.
model CatalystLink {
  id           String  @id @default(cuid())
  clusterId    String  @map("cluster_id")
  symbol       String
  /// The 1-day return at publish.
  ret1         Float?
  /// Relative volume against the 20-day average, at publish.
  rvol20       Float?
  /// Whether evidence exists for this ticker — gates the "Setup card" doorway. A doorway to nothing is worse
  /// than no doorway.
  hasSetupCard Boolean @map("has_setup_card")

  cluster NewsCluster @relation(fields: [clusterId], references: [id])

  @@unique([clusterId, symbol])
  @@map("catalyst_link")
}

/// A cached article image, fetched at INGEST and served from our own bucket — never hotlinked. Hotlinking a
/// publisher's photo at render rots (they move and expire), leaks the reader's IP to every publisher on the
/// page, breaks on referrer blocks, and makes layout shift unknowable (we never learn the dimensions).
/// Fetching once and storing the dimensions lets every card ship with width, height and a blur — CLS 0.000.
model NewsImage {
  /// sha1 of the source image url.
  id                String   @id
  /// Which rung of the sourcing ladder answered: "provider" | "og" | "favicon".
  sourceKind        String   @map("source_kind")
  urlFull           String   @map("url_full")
  urlCard           String   @map("url_card")
  urlThumb          String   @map("url_thumb")
  width             Int
  height            Int
  /// A ~300-byte base64 8px JPEG. Server-rendered, so it needs no client JS to paint.
  blurDataUrl       String   @map("blur_data_url")
  dominantColor     String   @map("dominant_color")
  /// Who took the photo, and the article it came from. Printed under the image, linked out.
  attributionSource String   @map("attribution_source")
  attributionUrl    String   @map("attribution_url")
  fetchedAt         DateTime @map("fetched_at")

  clusters NewsCluster[]

  @@map("news_image")
}

/// ✎ APP-WRITABLE — user state, the one table in this plan the app may write. The rule the system rests on:
/// the pipeline computes and writes; the app reads, and writes only what the USER did. A manual run is
/// something the user did, so the app records the REQUEST here and dispatches a GitHub Action — it never
/// fetches a provider or writes a pipeline table (a second, unaudited writer). The not_applicable and
/// not_configured states are absent from `status`: those are UI states of a run that was never requested.
model ManualRun {
  id          String    @id @default(cuid())
  requestedAt DateTime  @default(now()) @map("requested_at")
  /// "nightly-a" | "nightly-b"
  workflow    String
  /// "full" | "news" | "macro" | "compute" | "briefing"
  mode        String
  /// The GitHub Actions run this dispatch created, once GitHub tells us.
  ghRunId     BigInt?   @map("gh_run_id")
  /// requested | queued | running | succeeded | failed
  status      String
  reason      String?
  finishedAt  DateTime? @map("finished_at")

  @@index([requestedAt(sort: Desc)])
  @@map("manual_run")
}
